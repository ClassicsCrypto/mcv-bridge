# Bridge Environment (Required)
# Set to "production" for Ethereum Mainnet → ApeChain
# Set to "development" for testnet mode
NEXT_PUBLIC_BRIDGE_ENV=production

# RPC URLs (Required)
NEXT_PUBLIC_ETHEREUM_RPC_URL=your_ethereum_mainnet_rpc_url
NEXT_PUBLIC_APECHAIN_RPC_URL=https://apechain.calderachain.xyz/http

# Alchemy API Key (Required for NFT inventory)
ALCHEMY_API_KEY=your_alchemy_api_key
